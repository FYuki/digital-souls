# digital-souls 環境変数テンプレート
# このファイルをコピーして .env.development（開発）または .env.production（本番）を作成する
# cp .env.example .env.development

# ==========================================
# LLM（Ollama）
# ==========================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_SMALL=gemma3:4b
OLLAMA_MODEL_MEDIUM=

# ==========================================
# PostgreSQL
# ==========================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=digital_souls_dev        # 本番は digital_souls

# ==========================================
# Qdrant（ベクトル検索）
# ==========================================
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ==========================================
# Redis（キャッシュ）
# ==========================================
REDIS_HOST=localhost
REDIS_PORT=6379

# ==========================================
# AIRI（エージェント）
# ==========================================
AIRI_WS_URL=ws://localhost:3000      # server-runtimeのWebSocketポート（Phase 3で確定）

# ==========================================
# アプリケーション
# ==========================================
NODE_ENV=development                  # development | production
LOG_LEVEL=debug                       # debug | info | warn | error
