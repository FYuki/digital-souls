{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://digital-souls.local/schemas/profile-v1.schema.json",
  "title": "Digital Souls 環境プロファイル V1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "name", "description", "dependencies"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "description": { "type": "string", "minLength": 1 },
    "dependencies": {
      "type": "object",
      "additionalProperties": false,
      "required": ["frontend", "backend", "ollama", "voicevox", "whisper", "chroma"],
      "properties": {
        "frontend": { "$ref": "#/$defs/frontendDependency" },
        "backend": { "$ref": "#/$defs/backendDependency" },
        "ollama": { "$ref": "#/$defs/ollamaDependency" },
        "voicevox": { "$ref": "#/$defs/voicevoxDependency" },
        "whisper": { "$ref": "#/$defs/inProcessDependency" },
        "chroma": { "$ref": "#/$defs/inProcessDependency" }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "backend": {
                "properties": { "mode": { "const": "real" } },
                "required": ["mode"]
              }
            },
            "required": ["backend"]
          },
          "else": {
            "properties": {
              "ollama": { "$ref": "#/$defs/disabledDependency" },
              "voicevox": { "$ref": "#/$defs/disabledDependency" },
              "whisper": { "$ref": "#/$defs/disabledDependency" },
              "chroma": { "$ref": "#/$defs/disabledDependency" }
            }
          }
        }
      ]
    }
  },
  "$defs": {
    "connectionFields": {
      "baseUrl": {
        "type": "string",
        "format": "uri",
        "pattern": "^https?://(?![^?#]*%(?![0-9A-Fa-f]{2}))(?:\\[(?:(?:[0-9A-Fa-f]{1,4}:){7}[0-9A-Fa-f]{1,4}|(?:[0-9A-Fa-f]{1,4}:){1,7}:|(?:[0-9A-Fa-f]{1,4}:){1,6}:[0-9A-Fa-f]{1,4}|(?:[0-9A-Fa-f]{1,4}:){1,5}(?::[0-9A-Fa-f]{1,4}){1,2}|(?:[0-9A-Fa-f]{1,4}:){1,4}(?::[0-9A-Fa-f]{1,4}){1,3}|(?:[0-9A-Fa-f]{1,4}:){1,3}(?::[0-9A-Fa-f]{1,4}){1,4}|(?:[0-9A-Fa-f]{1,4}:){1,2}(?::[0-9A-Fa-f]{1,4}){1,5}|[0-9A-Fa-f]{1,4}:(?:(?::[0-9A-Fa-f]{1,4}){1,6})|:(?:(?::[0-9A-Fa-f]{1,4}){1,7}|:)|(?:[0-9A-Fa-f]{1,4}:){6}(?:(?:25[0-5]|2[0-4][0-9]|1[0-9]{2}|[1-9]?[0-9])\\.){3}(?:25[0-5]|2[0-4][0-9]|1[0-9]{2}|[1-9]?[0-9])|::(?:[fF]{4}(?::0{1,4})?:)?(?:(?:25[0-5]|2[0-4][0-9]|1[0-9]{2}|[1-9]?[0-9])\\.){3}(?:25[0-5]|2[0-4][0-9]|1[0-9]{2}|[1-9]?[0-9])|(?:[0-9A-Fa-f]{1,4}:){1,4}:(?:(?:25[0-5]|2[0-4][0-9]|1[0-9]{2}|[1-9]?[0-9])\\.){3}(?:25[0-5]|2[0-4][0-9]|1[0-9]{2}|[1-9]?[0-9]))\\]|[^/?#\\s:@\\[\\]]+)(?::[0-9]+)?(?:/[^?#\\s]*)?(?![\\s\\S])"
      },
      "readinessPath": {
        "type": "string",
        "pattern": "^/(?:[A-Za-z0-9._~!$&'()*+,;=:@]|%[0-9A-Fa-f]{2})+(?:/(?:[A-Za-z0-9._~!$&'()*+,;=:@]|%[0-9A-Fa-f]{2})*)*$|^/$"
      }
    },
    "disabledDependency": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "source"],
      "properties": {
        "mode": { "const": "disabled" },
        "source": { "type": "null" }
      }
    },
    "frontendDependency": {
      "oneOf": [
        { "$ref": "#/$defs/frontendManagedDependency" },
        { "$ref": "#/$defs/httpExternalDependency" },
        { "$ref": "#/$defs/disabledDependency" }
      ]
    },
    "frontendManagedDependency": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "source", "baseUrl", "readinessPath"],
      "properties": {
        "mode": { "const": "real" },
        "source": { "const": "managed" },
        "baseUrl": {
          "enum": ["http://localhost:5173", "http://localhost:5173/"]
        },
        "readinessPath": { "const": "/" }
      }
    },
    "httpExternalDependency": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "source", "baseUrl", "readinessPath"],
      "properties": {
        "mode": { "const": "real" },
        "source": { "const": "external" },
        "baseUrl": { "$ref": "#/$defs/connectionFields/baseUrl" },
        "readinessPath": { "$ref": "#/$defs/connectionFields/readinessPath" }
      }
    },
    "voicevoxDependency": {
      "oneOf": [
        { "$ref": "#/$defs/voicevoxManagedDependency" },
        { "$ref": "#/$defs/httpExternalDependency" },
        { "$ref": "#/$defs/disabledDependency" }
      ]
    },
    "ollamaDependency": {
      "oneOf": [
        { "$ref": "#/$defs/ollamaManagedDependency" },
        { "$ref": "#/$defs/httpExternalDependency" },
        { "$ref": "#/$defs/disabledDependency" }
      ]
    },
    "ollamaManagedDependency": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "source", "baseUrl", "readinessPath"],
      "properties": {
        "mode": { "const": "real" },
        "source": { "const": "managed" },
        "baseUrl": {
          "enum": [
            "http://localhost:11434",
            "http://localhost:11434/",
            "http://127.0.0.1:11434",
            "http://127.0.0.1:11434/"
          ]
        },
        "readinessPath": { "const": "/api/tags" }
      }
    },
    "voicevoxManagedDependency": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "source", "baseUrl", "readinessPath"],
      "properties": {
        "mode": { "const": "real" },
        "source": { "const": "managed" },
        "baseUrl": {
          "enum": [
            "http://localhost:50021",
            "http://localhost:50021/",
            "http://127.0.0.1:50021",
            "http://127.0.0.1:50021/"
          ]
        },
        "readinessPath": { "const": "/version" }
      }
    },
    "backendDependency": {
      "oneOf": [
        { "$ref": "#/$defs/backendManagedDependency" },
        { "$ref": "#/$defs/httpExternalDependency" },
        { "$ref": "#/$defs/browserMockDependency" },
        { "$ref": "#/$defs/disabledDependency" }
      ]
    },
    "backendManagedDependency": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "source", "baseUrl", "readinessPath"],
      "properties": {
        "mode": { "const": "real" },
        "source": { "const": "managed" },
        "baseUrl": {
          "enum": [
            "http://localhost:8000",
            "http://localhost:8000/",
            "http://127.0.0.1:8000",
            "http://127.0.0.1:8000/"
          ]
        },
        "readinessPath": { "const": "/" }
      }
    },
    "browserMockDependency": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "source"],
      "properties": {
        "mode": { "const": "mock" },
        "source": { "const": "browser" }
      }
    },
    "inProcessDependency": {
      "oneOf": [
        { "$ref": "#/$defs/inProcessRealDependency" },
        { "$ref": "#/$defs/disabledDependency" }
      ]
    },
    "inProcessRealDependency": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "source"],
      "properties": {
        "mode": { "const": "real" },
        "source": { "const": "in_process" }
      }
    }
  }
}
