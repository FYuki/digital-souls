{
  "name": "digital-souls-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "check": "svelte-check --tsconfig ./tsconfig.json && tsc --noEmit -p ./tsconfig.e2e.json",
    "build": "vite build",
    "install:browser": "playwright install --with-deps chromium",
    "preview": "vite preview",
    "test": "vitest run",
    "test:unit": "vitest run .unit.test.ts",
    "test:module": "vitest run .module.test.ts",
    "test:e2e:mocked": "playwright test --config playwright.mocked.config.ts",
    "test:integration:text": "playwright test --config playwright.integration-text.config.ts",
    "test:integration:voice": "playwright test --config playwright.integration-voice.config.ts"
  },
  "dependencies": {
    "@ricky0123/vad-web": "^0.0.30",
    "@sveltejs/vite-plugin-svelte": "^3.1.2",
    "onnxruntime-web": "^1.27.0",
    "svelte": "^4.2.20",
    "vite": "^5.4.19"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/svelte": "^4.2.3",
    "@tsconfig/svelte": "^5.0.4",
    "jsdom": "^24.1.3",
    "svelte-check": "^3.8.6",
    "typescript": "^5.8.3",
    "vitest": "^2.1.9"
  }
}
